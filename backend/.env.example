# Backend local-dev environment. Copy to backend/.env and fill in.
# (In production these are set as Render env vars / secrets — see render.yaml.)

ENVIRONMENT=development

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=generate_a_random_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# Allowed frontend origins (comma-separated, no trailing slash)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database — SQLite for dev; Postgres (Neon) for production.
DATABASE_URL=sqlite:///./sql_app.db
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Storage — local disk by default (no cloud needed).
STORAGE_BACKEND=local
DATA_DIR=data

# AI
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=

# RAG (local embeddings). Set false to disable on low-memory machines.
ENABLE_RAG=true

# Google sign-in (optional)
GOOGLE_CLIENT_ID=

# Azure Blob (only if STORAGE_BACKEND=azure)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=patient-reports
