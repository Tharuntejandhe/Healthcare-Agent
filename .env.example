# ===== App =====
PROJECT_NAME=MediHealth System
ENVIRONMENT=development  # development | staging | production

# ===== Security =====
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change_me_in_production_to_a_long_random_value
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days

# Comma-separated list of allowed frontend origins (no trailing slash).
# In production this MUST be your real frontend domain(s); "*" is rejected.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Logging =====
LOG_LEVEL=INFO

# ===== Database =====
# Dev uses SQLite; production REQUIRES Postgres (e.g. Neon). SQLite is rejected
# when ENVIRONMENT=production.
DATABASE_URL=sqlite:///sql_app.db
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ===== Storage =====
# "local" (default, no cloud dependency) or "azure".
STORAGE_BACKEND=local
# Where uploads + FAISS indexes + the embedding-model cache live.
# On Render, point this at a mounted disk (e.g. /app/data).
DATA_DIR=data
# Upload size caps (MB)
MAX_UPLOAD_MB=15
MAX_IMAGE_MB=10
MAX_AUDIO_MB=25

# ===== AI =====
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=            # optional — enables web search in the senior-doctor agent
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_TIMEOUT_SECONDS=60
GROQ_MAX_RETRIES=2

# RAG / embeddings (local, free, CPU). Needs ~1GB RAM; set false on tiny instances.
ENABLE_RAG=true
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ===== Rate limiting =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_AI=20/minute
RATE_LIMIT_DEFAULT=120/minute
# RATE_LIMIT_STORAGE_URI=memory://   # use redis://... to share limits across workers

# ===== Azure Storage (only if STORAGE_BACKEND=azure) =====
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=patient-reports

# ===== Google OAuth =====
# Web client ID from Google Cloud Console -> APIs & Services -> Credentials.
# Same value goes into the frontend as NEXT_PUBLIC_GOOGLE_CLIENT_ID. Optional.
GOOGLE_CLIENT_ID=

# ===== Frontend (Next.js) =====
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
